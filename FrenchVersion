}

void update_screens(int alert_type) {
  int x, y;

  for (y = 18; y < 45; y++) {
    for (x = 9; x < 32; x++) {
      write_char(x, y, ' ');
    }
  }

  for (y = 12; y < 32; y++) {
    for (x = 47; x < 74; x++) {
      write_char(x, y, ' ');
    }
  }

  for (y = 39; y < 52; y++) {
    for (x = 47; x < 74; x++) {
      write_char(x, y, ' ');
    }
  }

  draw_rect(40, 75, 120, 175, SAFE_BG);
  draw_rect(187, 42, 293, 218, SAFE_BG);

  if (alert_type > 0) {
    draw_rect(40, 108, 120, 142, WHITE);
    draw_rect(42, 110, 118, 140, RED);
    draw_rect(190, 92, 290, 124, WHITE);
    draw_rect(192, 94, 288, 122, RED);

    write_string(14, 22, "EMERGENCY");
    write_string(13, 40, "Calling SOS");
    write_string(53, 14, "CRITICAL ALERT");
    write_string(53, 20, "Calling SOS...");
    write_string(52, 45, "Assistance mode");
    write_string(55, 48, "ACTIVATED");

    if (alert_type == 1) {
      write_string(15, 31, "Manual SOS");
      write_string(56, 24, "Reason:");
      write_string(53, 27, "User Manual SOS");
    } else if (alert_type == 2) {
      write_string(15, 31, "Drop >18cm");
      write_string(56, 24, "Reason:");
      write_string(53, 27, "Dangerous Drop");
    } else if (alert_type == 3) {
      write_string(15, 31, "Slow Fall");
      write_string(56, 24, "Reason:");
      write_string(51, 27, "Slow Fall Detected");
    } else if (alert_type == 4) {
      write_string(15, 31, "FAST FALL!");
      write_string(56, 24, "Reason:");
      write_string(51, 27, "FAST FALL Detected");
    }
  } else {
    write_string(16, 24, "12:00 PM");
    write_string(15, 29, "Status: OK");
    write_string(16, 33, "BPM: 72");
    write_string(55, 14, "App Active");
    write_string(53, 22, "User is safe.");
    write_string(52, 24, "Sensors normal.");
  }

  write_string(54, 50, "Battery: 85%");
}

void update_distance_display(int dist1, int dist2) {
  char buf[20];
  int row, x;

  for (row = 32; row <= 38; row++) {
    for (x = 47; x < 74; x++) {
      write_char(x, row, ' ');
    }
  }

  write_string(52, 33, "=== SENSORS ===");

  if (dist1 < 0) {
    write_string(51, 35, "Obstacle:  --- cm");
  } else {
    sprintf(buf, "Obstacle: %3d cm", dist1);
    write_string(51, 35, buf);
  }

  if (dist2 < 0) {
    write_string(51, 37, "    Drop:  --- cm");
  } else {
    sprintf(buf, "    Drop: %3d cm", dist2);
    write_string(51, 37, buf);
  }
}

int handle_vibration_tap(int assist_mode, int d_fwd, int d_down, int *p_alert,
                         int *p_last) {
  int taps = g_tap_count;

  g_tap_count = 0;
  g_vib_triggered = 0;

  if (assist_mode) {
    if (taps >= 3) {
      assist_mode = 0;
      *p_alert = 0;
      show_disengage();
      update_screens(0);
      update_distance_display(d_fwd, d_down);
      *p_last = 0;
      play_disengage_sound();
      delay_us(500000);
      *hex = 0x00000000;
      *hex54 = 0x00000000;
      start_mode_lockout();
    }
  } else {
    if (taps >= 1 && taps <= 2) {
      assist_mode = 1;
      *p_alert = 1;
      show_assist();
      update_screens(1);
      update_distance_display(d_fwd, d_down);
      *p_last = 1;
      start_mode_lockout();
      play_emergency_siren();
    }
  }

  return assist_mode;
}

float distance_read_down(HCSR04_t *s) {
  int timeout;
  volatile int count;
  int echo_timeout;

  digitalWrite(s->gpio, s->trig_pin, 0);
  delay_us(2);
  digitalWrite(s->gpio, s->trig_pin, 1);
  delay_us(10);
  digitalWrite(s->gpio, s->trig_pin, 0);

  timeout = 1200000;
  while (digitalRead(s->gpio, s->echo_pin) == 0 && timeout-- > 0) {
    poll_vibration();
    if (g_vib_triggered) return -1.0f;
  }
  if (timeout <= 0) return -1.0f;

  count = 0;
  echo_timeout = 1200000;
  while (digitalRead(s->gpio, s->echo_pin) == 1 && echo_timeout-- > 0) {
    poll_vibration();
    if (g_vib_triggered) return -1.0f;
    count++;
  }

  return (float)count / 26.25f;  // calibrated for downward sensor
}

int main(void) {
  volatile int *pixel_ctrl_ptr = (int *)PIXEL_CTRL_BASE;
  HCSR04_t sensor1;
  HCSR04_t sensor2;

  int assist_mode;
  int current_alert_state;
  int last_alert_state;
  int d_fwd;
  int d_down;

  pixel_buffer_start = *pixel_ctrl_ptr;
  clear_text();
  draw_static_chassis();
  update_screens(0);
  update_distance_display(0, 0);

  reset_audio_core();

  *hex = 0x3F3F3F3F;
  *hex54 = 0x00003F3F;

  sensor1.gpio = jp2;
  sensor1.trig_pin = 5;
  sensor1.echo_pin = 6;

  sensor2.gpio = jp2;
  sensor2.trig_pin = 3;
  sensor2.echo_pin = 4;

  pinMode(jp2, sensor1.trig_pin, 1);
  pinMode(jp2, sensor1.echo_pin, 0);
  pinMode(jp2, sensor2.trig_pin, 1);
  pinMode(jp2, sensor2.echo_pin, 0);
  pinMode(jp2, VIB_PIN, 0);

  digitalWrite(jp2, sensor1.trig_pin, 0);
  digitalWrite(jp2, sensor2.trig_pin, 0);

  delay_us(500000);

  s_vib_prev = (jp2->DATA >> VIB_PIN) & 1;
  s_vib_debounce = 0;
  g_vib_triggered = 0;
  g_tap_count = 0;
  s_vib_armed = 0;
  s_vib_low_count = 0;
  s_mode_lockout = 0;

  *hex = 0x00000000;
  *hex54 = 0x00000000;

  assist_mode = 0;
  current_alert_state = 0;
  last_alert_state = 0;
  d_fwd = 0;
  d_down = 0;

  while (1) {
    float dist_fwd;
    float dist_down;

    if (g_vib_triggered) {
      int window_ticks = 3000;
      g_vib_triggered = 0;

      while (window_ticks > 0) {
        delay_us(100);
        poll_vibration();
        window_ticks--;
      }

      assist_mode = handle_vibration_tap(
          assist_mode, d_fwd, d_down, &current_alert_state, &last_alert_state);
      continue;
    }

    dist_fwd = distance_read(&sensor1);
    delay_us(500);
    if (g_vib_triggered) continue;

    dist_down = distance_read_down(&sensor2);
    delay_us(500);
    if (g_vib_triggered) continue;

    d_fwd = (dist_fwd < 0.0f) ? -1 : (int)dist_fwd;
    d_down = (dist_down < 0.0f) ? -1 : (int)dist_down;

    if (!assist_mode) {
      int fall_state = detect_fall_state(dist_down);

      if (fall_state == 1|| fall_state == 2) {
        int i;
        assist_mode = 1;
        current_alert_state = 4;
        show_fall();
        update_screens(4);
        update_distance_display(d_fwd, d_down);
        last_alert_state = 4;
        start_mode_lockout();
        for (i = 0; i < 3 && !g_vib_triggered; i++) {
          play_emergency_siren();
        }
      } else if (fall_state == 2) {
        assist_mode = 1;
        current_alert_state = 3;
        show_slow_fall();
        update_screens(3);
        update_distance_display(d_fwd, d_down);
        last_alert_state = 3;
        start_mode_lockout();
        play_slow_fall_alert();
      }
    }

    if (!assist_mode) {
      if (dist_fwd < 0)
        display_error1();
      else
        display_distance1(d_fwd);

      if (dist_down < 0)
        display_error2();
      else
        display_distance2(d_down);

      if (dist_down >= 0.0f) {
        if (dist_down >= LEDGE_DANGER) {
          assist_mode = 1;
          current_alert_state = 2;
          show_assist();
          update_screens(2);
          update_distance_display(d_fwd, d_down);
          last_alert_state = 2;
          start_mode_lockout();
          play_emergency_siren();
        } else if (dist_down >= LEDGE_WARN_HIGH) {
          play_ledge_alert(0);
        } else if (dist_down >= LEDGE_WARN_MID) {
          play_ledge_alert(1);
        } else if (dist_down >= LEDGE_WARN_LOW) {
          play_ledge_alert(2);
        }
      }

      if (dist_fwd > 0.0f && dist_fwd <= 100.0f) {
        int vs;
        if (dist_fwd > 60)
          vs = 2;
        else if (dist_fwd > 30)
          vs = 1;
        else
          vs = 0;
        play_obstacle_alert(vs);
      }

      current_alert_state = 0;
      if (current_alert_state != last_alert_state) {
        update_screens(0);
        last_alert_state = 0;
      }
    }

    update_distance_display(d_fwd, d_down);
  }

  return 0;
}
