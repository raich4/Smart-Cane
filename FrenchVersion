#define JP2_BASE 0xFF200070
#define HEX3_HEX0_BASE 0xFF200020
#define HEX5_HEX4_BASE 0xFF200030
#define AUDIO_BASE 0xFF203040
#define PIXEL_CTRL_BASE 0xFF203020
#define CHAR_BUFFER_BASE 0x09000000

#define VIB_PIN 2
#define VIB_DEBOUNCE_TICKS 80
#define TAP_SILENCE_TICKS 200

#define VIB_ARM_LOW_TICKS 250
#define MODE_LOCKOUT_POLLS 4000

#define AUDIO_WAIT_LIMIT 200000
#define AUDIO_RESET_DELAY 2000

#define MOUNT_HEIGHT 10.0f
#define LEDGE_WARN_LOW (MOUNT_HEIGHT + 5.0f)
#define LEDGE_WARN_MID (MOUNT_HEIGHT + 8.0f)
#define LEDGE_WARN_HIGH (MOUNT_HEIGHT + 10.0f)
#define LEDGE_DANGER (MOUNT_HEIGHT + 15.0f)
#define S2_OPEN_AIR (MOUNT_HEIGHT + 25.0f)
#define FAST_FALL_VELOCITY 15.0f
#define SLOW_FALL_SUSTAIN 12
#define BASELINE_MARGIN (MOUNT_HEIGHT + 4.0f)
#define LEDGE_RETURN_WINDOW 8

#define BLACK 0x0000
#define WHITE 0xFFFF
#define RED 0xF800
#define CYAN 0x07FF
#define LIGHT_BG 0xDF1E
#define DARK_GREY 0x3186
#define MED_GREY 0x8410
#define STRAP_COLOR 0x18E3
#define SAFE_BG 0x2124

typedef struct {
  volatile unsigned int CONTROL;
  volatile unsigned int FIFOSPACE;
  volatile unsigned int LEFTDATA;
  volatile unsigned int RIGHTDATA;
} AUDIO_t;

typedef struct {
  volatile unsigned int DATA;
  volatile unsigned int DDR;
} GPIO_t;

typedef struct {
  GPIO_t *gpio;
  int trig_pin;
  int echo_pin;
} HCSR04_t;

AUDIO_t *audio = (AUDIO_t *)AUDIO_BASE;
volatile int *hex = (volatile int *)HEX3_HEX0_BASE;
volatile int *hex54 = (volatile int *)HEX5_HEX4_BASE;
GPIO_t *jp2 = (GPIO_t *)JP2_BASE;
volatile int pixel_buffer_start;

volatile int g_vib_triggered = 0;
volatile int g_tap_count = 0;

static int s_vib_prev = 0;
static int s_vib_debounce = 0;
static int s_vib_armed = 0;
static int s_vib_low_count = 0;
static int s_mode_lockout = 0;

const unsigned char seg7[] = {0x3F, 0x06, 0x5B, 0x4F, 0x66,
                              0x6D, 0x7D, 0x07, 0x7F, 0x6F};

void pinMode(GPIO_t *gpio, int pin, int mode) {
  if (mode == 1)
    gpio->DDR |= (1 << pin);
  else
    gpio->DDR &= ~(1 << pin);
}

void digitalWrite(GPIO_t *gpio, int pin, int val) {
  if (val)
    gpio->DATA |= (1 << pin);
  else
    gpio->DATA &= ~(1 << pin);
}

int digitalRead(GPIO_t *gpio, int pin) { return (gpio->DATA >> pin) & 1; }

void delay_us(int us) {
  volatile int i;
  for (i = 0; i < us * 40; i++);
}

static inline void reset_audio_core(void) {
  audio->CONTROL = 0xC;
  delay_us(AUDIO_RESET_DELAY);
  audio->CONTROL = 0x0;
  delay_us(AUDIO_RESET_DELAY);
}

static inline void clear_vib_state(void) {
  g_vib_triggered = 0;
  g_tap_count = 0;
  s_vib_debounce = 0;
  s_vib_prev = (jp2->DATA >> VIB_PIN) & 1;
}

static inline void start_mode_lockout(void) {
  s_mode_lockout = MODE_LOCKOUT_POLLS;
  clear_vib_state();
}

static inline void poll_vibration(void) {
  int current = (jp2->DATA >> VIB_PIN) & 1;

  if (!s_vib_armed) {
    if (current == 0) {
      s_vib_low_count++;
      if (s_vib_low_count >= VIB_ARM_LOW_TICKS)
        s_vib_armed = 1;
    } else {
      s_vib_low_count = 0;
    }
    s_vib_prev = current;
    return;
  }

  if (s_mode_lockout > 0) {
    s_mode_lockout--;
    s_vib_prev = current;
    return;
  }

  if (s_vib_debounce > 0) {
    s_vib_debounce--;
    s_vib_prev = current;
    return;
  }

  if (current == 1 && s_vib_prev == 0) {
    g_tap_count++;
    g_vib_triggered = 1;
    s_vib_debounce = VIB_DEBOUNCE_TICKS;
  }

  s_vib_prev = current;
}

void display_distance1(int cm) {
  if (cm > 999) cm = 999;
  if (cm < 0) cm = 0;
  *hex54 = (seg7[(cm / 100) % 10] << 8) | seg7[(cm / 10) % 10];
  *hex = (*hex & 0x00FFFFFF) | (seg7[cm % 10] << 24);
}

void display_distance2(int cm) {
  if (cm > 999) cm = 999;
  if (cm < 0) cm = 0;
  *hex = (*hex & 0xFF000000) | (seg7[(cm / 100) % 10] << 16) |
         (seg7[(cm / 10) % 10] << 8) | seg7[cm % 10];
}

void display_error1(void) {
  *hex54 = (0x79 << 8) | 0x50;
  *hex = (*hex & 0x00FFFFFF) | (0x50 << 24);
}

void display_error2(void) {
  *hex = (*hex & 0xFF000000) | (0x79 << 16) | (0x50 << 8) | 0x50;
}

void show_fall(void) {
  *hex54 = (0x71 << 8) | 0x77;
  *hex = (0x38 << 24) | (0x38 << 16);
}

void show_slow_fall(void) {
  *hex54 = (0x6D << 8) | 0x38;
  *hex = (*hex & 0x00FFFFFF) | (0x3F << 24);
}

void show_assist(void) {
  *hex54 = 0;
  *hex = (0x77 << 24) | (0x6D << 16) | (0x6D << 8) | 0x78;
}

void show_disengage(void) {
  *hex54 = 0;
  *hex = (0x5E << 24) | (0x06 << 16) | (0x6D << 8) | 0x79;
}

static inline bool fifo_has_space(void) {
  unsigned int fs = audio->FIFOSPACE;
  return (((fs >> 24) & 0xFF) > 0) && (((fs >> 16) & 0xFF) > 0);
}

int play_pcm(const int *array, int length, int vol_shift) {
  int i;
  for (i = 0; i < length; i++) {
    int wait_count = 0;

    poll_vibration();
    if (g_vib_triggered) return 0;

    while (!fifo_has_space()) {
      poll_vibration();
      if (g_vib_triggered) return 0;

      wait_count++;
      if (wait_count > AUDIO_WAIT_LIMIT) {
        reset_audio_core();
        return -1;
      }
    }

    audio->LEFTDATA = array[i] >> vol_shift;
    audio->RIGHTDATA = array[i] >> vol_shift;
  }
  return 1;
}

void play_obstacle_alert(int vol_shift) {
  play_pcm(objet_array, OBJET_ARRAY_LENGTH, vol_shift);
}

void play_ledge_alert(int vol_shift) {
  play_pcm(bord_array, BORD_ARRAY_LENGTH, vol_shift);
}

void play_emergency_siren(void) {
  reset_audio_core();
  play_pcm(assistance_array, ASSISTANCE_ARRAY_LENGTH, 0);
}

void play_slow_fall_alert(void) {
  reset_audio_core();
  play_pcm(assistance_array, ASSISTANCE_ARRAY_LENGTH, 0);
  if (!g_vib_triggered)
    play_pcm(assistance_array, ASSISTANCE_ARRAY_LENGTH, 0);
}

void play_disengage_sound(void) {
  reset_audio_core();
  play_pcm(assist_desactive_array, ASSIST_DESACTIVE_ARRAY_LENGTH, 0);
}

float distance_read(HCSR04_t *s) {
  int timeout;
  volatile int count;
  int echo_timeout;

  digitalWrite(s->gpio, s->trig_pin, 0);
  delay_us(2);
  digitalWrite(s->gpio, s->trig_pin, 1);
  delay_us(10);
  digitalWrite(s->gpio, s->trig_pin, 0);

  timeout = 1200000;
  while (digitalRead(s->gpio, s->echo_pin) == 0 && timeout-- > 0) {
    poll_vibration();
    if (g_vib_triggered) return -1.0f;
  }
  if (timeout <= 0) return -1.0f;

  count = 0;
  echo_timeout = 1200000;
  while (digitalRead(s->gpio, s->echo_pin) == 1 && echo_timeout-- > 0) {
    poll_vibration();
    if (g_vib_triggered) return -1.0f;
    count++;
  }

  return (float)count / 33.3f;
}

typedef enum { STATE_NORMAL, STATE_ELEVATED, STATE_OPEN_AIR } FallState;

int detect_fall_state(float d_down) {
  static FallState state = STATE_NORMAL;
  static float prev_d = -1.0f;
  static int sustain_count = 0;
  static int return_timer = 0;

  float d;
  float velocity;

  if (prev_d < 0.0f) {
    prev_d = (d_down >= 0.0f) ? d_down : MOUNT_HEIGHT;
    return 0;
  }

  d = (d_down < 0.0f) ? (S2_OPEN_AIR + 10.0f) : d_down;
  velocity = d - prev_d;
  prev_d = d;

  switch (state) {
    case STATE_NORMAL:
      if (d > S2_OPEN_AIR) {
        sustain_count = 1;
        return_timer = 0;
        state = STATE_OPEN_AIR;
        if (velocity >= FAST_FALL_VELOCITY) {
          state = STATE_NORMAL;
          sustain_count = 0;
          prev_d = MOUNT_HEIGHT;
          return 1;
        }
      } else if (d > LEDGE_WARN_LOW) {
        state = STATE_ELEVATED;
        return_timer = 0;
      }
      break;

    case STATE_ELEVATED:
      if (d <= BASELINE_MARGIN) {
        state = STATE_NORMAL;
        return_timer = 0;
      } else if (d > S2_OPEN_AIR) {
        sustain_count = 1;
        return_timer = 0;
        state = STATE_OPEN_AIR;
        if (velocity >= FAST_FALL_VELOCITY) {
          state = STATE_NORMAL;
          sustain_count = 0;
          prev_d = MOUNT_HEIGHT;
          return 1;
        }
      } else {
        return_timer++;
        if (return_timer > LEDGE_RETURN_WINDOW) {
          state = STATE_OPEN_AIR;
          sustain_count = return_timer;
          return_timer = 0;
        }
      }
      break;

    case STATE_OPEN_AIR:
      if (d <= BASELINE_MARGIN) {
        state = STATE_NORMAL;
        sustain_count = 0;
        return_timer = 0;
      } else if (d > S2_OPEN_AIR) {
        sustain_count++;
        if (velocity >= FAST_FALL_VELOCITY) {
          state = STATE_NORMAL;
          sustain_count = 0;
          prev_d = MOUNT_HEIGHT;
          return 1;
        }
        if (sustain_count >= SLOW_FALL_SUSTAIN) {
          state = STATE_NORMAL;
          sustain_count = 0;
          return_timer = 0;
          return 2;
        }
      } else {
        return_timer++;
        if (return_timer > LEDGE_RETURN_WINDOW) {
          state = STATE_NORMAL;
          sustain_count = 0;
          return_timer = 0;
          return 2;
        }
      }
      break;
  }

  return 0;
}

void plot_pixel(int x, int y, short int color) {
  if (x >= 0 && x < 320 && y >= 0 && y < 240) {
    volatile short int *addr;
    addr = (short int *)(pixel_buffer_start + (y << 10) + (x << 1));
    *addr = color;
  }
}

void write_char(int x, int y, char c) {
  if (x >= 0 && x < 80 && y >= 0 && y < 60) {
    volatile char *cb;
    cb = (char *)(CHAR_BUFFER_BASE + (y << 7) + x);
    *cb = c;
  }
}

void write_string(int x, int y, char *str) {
  int i;
  for (i = 0; str[i] != '\0'; i++) {
    write_char(x + i, y, str[i]);
  }
}

void draw_rect(int x1, int y1, int x2, int y2, short int color) {
  int x, y;
  for (y = y1; y <= y2; y++) {
    for (x = x1; x <= x2; x++) {
      plot_pixel(x, y, color);
    }
  }
}

void clear_text(void) {
  int x, y;
  for (y = 0; y < 60; y++) {
    for (x = 0; x < 80; x++) {
      write_char(x, y, ' ');
    }
  }
}

