    float dist1 = distance(&sensor1);
        display_distance(dist1);

        // Alert Logic for Sensor 1
        if (dist1 > 0 && dist1 <= 30) {
            if(dist1 > 20){
                volume = (0x3FFFFFFF) / 4; // Mid-range warning
            }
            else if (dist1 > 10) {
                volume = (0x3FFFFFFF) / 2; // Mid-range warning
            } else {
                volume = 0x3FFFFFFF;       // Critical distance
            }
            play_obstacle_alert(volume);
        }

        delay(60000); // 60ms cool-down to prevent echo interference
}

