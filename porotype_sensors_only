/*******************************************************************************
 * Assistive cane — DE1-SoC bare-metal
 *
 * Device is mounted ~5 cm above the floor at the base of the cane.
 *
 * Sensor roles:
 *   Sensor 1 — top face, pointing DOWN
 *       Reads ground ~5 cm below. Used for ledge / step / drop detection.
 *       Ignored for fall detection (distance barely changes when cane tips).
 *
 *   Sensor 2 — side face, pointing FORWARD
 *       Reads obstacles at ankle/shin height during normal use.
 *       Used for fall detection: when cane tips over the forward sensor
 *       sweeps into open air and reads max range or times out.
 *
 * Fall detection:
 *   FALL_OPEN_AIR   — if sensor 2 reads above this (cm), counts as open-air.
 *   FALL_CONFIRM    — how many consecutive open-air reads confirm a fall.
 *                     Prevents a single open-corridor step from triggering.
 *
 * JP2 pin mapping:
 *   bit 3 — sensor 2 TRIG  (output)
 *   bit 4 — sensor 2 ECHO  (input)
 *   bit 5 — sensor 1 TRIG  (output)
 *   bit 6 — sensor 1 ECHO  (input)
 ******************************************************************************/

#include <stdlib.h>
#include <stdbool.h>

#define JP2_BASE        0xFF200070
#define HEX3_HEX0_BASE  0xFF200020
#define HEX5_HEX4_BASE  0xFF200030
#define AUDIO_BASE      0xFF203040
#define SAMPLE_RATE     8000

// ── Tuning constants ─────────────────────────────────────────────────────────

// Sensor 2 (forward): above this distance (cm) = cane is tipped / open air
#define FALL_OPEN_AIR       150.0f

// How many consecutive open-air reads before triggering fall alert
// Lower = faster response, higher = fewer false positives in open spaces
#define FALL_CONFIRM        3

// Sensor 1 (down): ledge thresholds (cm above ground)
// Normal cane-tip height ≈ 5 cm. A drop/ledge raises this significantly.
#define LEDGE_DANGER        15.0f   // emergency — large drop
#define LEDGE_WARN_HIGH     10.0f   // strong warning
#define LEDGE_WARN_MID       8.0f   // medium warning
#define LEDGE_WARN_LOW       6.5f   // gentle warning

// ─────────────────────────────────────────
// PERIPHERAL STRUCTS
// ─────────────────────────────────────────
typedef struct {
    volatile unsigned int CONTROL;
    volatile unsigned int FIFOSPACE;
    volatile unsigned int LEFTDATA;
    volatile unsigned int RIGHTDATA;
} AUDIO_t;

typedef struct {
    volatile unsigned int DATA;
    volatile unsigned int DDR;
} GPIO_t;

typedef struct {
    GPIO_t *gpio;
    int     trig_pin;
    int     echo_pin;
} HCSR04_t;

AUDIO_t      *audio = (AUDIO_t *)AUDIO_BASE;
volatile int *hex   = (volatile int *)HEX3_HEX0_BASE;
volatile int *hex54 = (volatile int *)HEX5_HEX4_BASE;
GPIO_t       *jp2   = (GPIO_t *)JP2_BASE;

const unsigned char seg7[] = {
    0x3F, 0x06, 0x5B, 0x4F, 0x66,
    0x6D, 0x7D, 0x07, 0x7F, 0x6F
};

// ─────────────────────────────────────────
// GPIO
// ─────────────────────────────────────────
void pinMode(GPIO_t *gpio, int pin, int mode) {
    if (mode == 1) gpio->DDR |=  (1 << pin);
    else           gpio->DDR &= ~(1 << pin);
}

void digitalWrite(GPIO_t *gpio, int pin, int val) {
    if (val) gpio->DATA |=  (1 << pin);
    else     gpio->DATA &= ~(1 << pin);
}

int digitalRead(GPIO_t *gpio, int pin) {
    return (gpio->DATA >> pin) & 1;
}

void delay_us(int us) {
    volatile int i;
    for (i = 0; i < us * 40; i++);
}

// ─────────────────────────────────────────
// HEX DISPLAY
// ─────────────────────────────────────────
void display_distance1(int cm) {
    if (cm > 999) cm = 999;
    if (cm < 0)   cm = 0;
    *hex54 = (seg7[(cm / 100) % 10] << 8) | seg7[(cm / 10) % 10];
    *hex   = (*hex & 0x00FFFFFF) | (seg7[cm % 10] << 24);
}

void display_distance2(int cm) {
    if (cm > 999) cm = 999;
    if (cm < 0)   cm = 0;
    *hex = (*hex & 0xFF000000)
         | (seg7[(cm / 100) % 10] << 16)
         | (seg7[(cm / 10)  % 10] <<  8)
         |  seg7[cm % 10];
}

void display_error1(void) {
    // "Err" on HEX5-HEX3
    *hex54 = (0x79 << 8) | 0x50;
    *hex   = (*hex & 0x00FFFFFF) | (0x50 << 24);
}

void display_error2(void) {
    // "Err" on HEX2-HEX0
    *hex = (*hex & 0xFF000000) | (0x79 << 16) | (0x50 << 8) | 0x50;
}

// "FALL" across all six digits
void show_fall(void) {
    // F=0x71  A=0x77  L=0x38  L=0x38
    *hex54 = (0x71 << 8) | 0x77;
    *hex   = (0x38 << 24) | (0x38 << 16) | 0x0000;
}

// "ASST" (assist mode active)
void show_assist(void) {
    *hex54 = 0x00000000;
    *hex   = (0x77 << 24) | (0x6D << 16) | (0x6D << 8) | 0x78;
}

// "dISE" (disengaged)
void show_disengage(void) {
    *hex54 = 0x00000000;
    *hex   = (0x5E << 24) | (0x06 << 16) | (0x6D << 8) | 0x79;
}

// ─────────────────────────────────────────
// AUDIO
// ─────────────────────────────────────────
static bool FIFOspace(void) {
    unsigned int fs = audio->FIFOSPACE;
    return ((fs >> 24) & 0xFF) > 0 && ((fs >> 16) & 0xFF) > 0;
}

void play_sample(int s) {
    while (!FIFOspace());
    audio->LEFTDATA  = s;
    audio->RIGHTDATA = s;
}

void play_tone(int freq, int duration_ms, int vol) {
    if (freq == 0) {
        int n = (SAMPLE_RATE * duration_ms) / 1000;
        for (int i = 0; i < n; i++) play_sample(0);
        return;
    }
    int half = SAMPLE_RATE / freq / 2;
    int n    = (SAMPLE_RATE * duration_ms) / 1000;
    int cnt  = 0;
    bool hi  = true;
    for (int i = 0; i < n; i++) {
        play_sample(hi ? vol : -vol);
        if (++cnt >= half) { hi = !hi; cnt = 0; }
    }
}

void play_obstacle_alert(int vol) {
    play_tone(1000, 100, vol);
    play_tone(0,    100, vol);
}

void play_ledge_alert(int vol) {
    play_tone(300, 400, vol);
    play_tone(0,   100, vol);
}

void play_emergency_siren(int vol) {
    play_tone(600, 300, vol);
    play_tone(800, 300, vol);
}

// ─────────────────────────────────────────
// HC-SR04
// ─────────────────────────────────────────
float distance_read(HCSR04_t *s) {
    digitalWrite(s->gpio, s->trig_pin, 0);
    delay_us(2);
    digitalWrite(s->gpio, s->trig_pin, 1);
    delay_us(10);
    digitalWrite(s->gpio, s->trig_pin, 0);

    // Wait for echo HIGH
    int timeout = 1200000;
    while (digitalRead(s->gpio, s->echo_pin) == 0 && timeout-- > 0);
    if (timeout <= 0) return -1.0f;   // nothing detected / sensor timeout

    // Count echo HIGH duration
    volatile int count = 0;
    int echo_timeout   = 1200000;
    while (digitalRead(s->gpio, s->echo_pin) == 1 && echo_timeout-- > 0)
        count++;

    return (float)count / 150.0f;
}

// ─────────────────────────────────────────
// FALL DETECTION  (sensor 2 — forward-facing only)
//
// A fall tips the cane so sensor 2 sweeps into open air.
// We confirm over FALL_CONFIRM consecutive readings to avoid
// false positives when walking in open corridors.
//
// Returns 1 on confirmed fall, 0 otherwise.
// ─────────────────────────────────────────
int detect_fall(float fwd_dist) {
    static int open_air_count = 0;

    // Open-air condition: reading above threshold OR sensor timeout (-1)
    bool is_open = (fwd_dist < 0.0f || fwd_dist > FALL_OPEN_AIR);

    if (is_open) {
        open_air_count++;
    } else {
        // Cane is back upright — clear counter
        open_air_count = 0;
    }

    // Debug: show open_air_count on HEX1-HEX0 so you can watch it climb
    // Remove this line once fall detection is confirmed working
    *hex = (*hex & 0xFFFFFF00) | seg7[open_air_count < 10 ? open_air_count : 9];

    if (open_air_count >= FALL_CONFIRM) {
        open_air_count = 0;   // reset so it doesn't re-trigger immediately
        return 1;
    }

    return 0;
}

// ─────────────────────────────────────────
// MAIN
// ─────────────────────────────────────────
int main(void) {
    audio->CONTROL = 0xC;
    audio->CONTROL = 0x0;

    // Sensor 1: top face, pointing down — ledge detection
    HCSR04_t sensor1 = { jp2, 5, 6 };
    pinMode(jp2, sensor1.trig_pin, 1);
    pinMode(jp2, sensor1.echo_pin, 0);

    // Sensor 2: side face, pointing forward — obstacle + fall detection
    HCSR04_t sensor2 = { jp2, 3, 4 };
    pinMode(jp2, sensor2.trig_pin, 1);
    pinMode(jp2, sensor2.echo_pin, 0);

    digitalWrite(jp2, sensor1.trig_pin, 0);
    digitalWrite(jp2, sensor2.trig_pin, 0);

    *hex   = 0x00000000;
    *hex54 = 0x00000000;

    int assist_mode = 0;

    while (1) {
        // ── Read sensors ─────────────────────────────────────────────────
        float dist_down = distance_read(&sensor1);   // cm to ground below
        delay_us(500);
        float dist_fwd  = distance_read(&sensor2);   // cm to obstacle ahead
        delay_us(500);

        // ── Fall detection (forward sensor only) ─────────────────────────
        if (!assist_mode && detect_fall(dist_fwd)) {
            assist_mode = 1;
            show_fall();
            play_emergency_siren(0x3FFFFFFF);
            play_emergency_siren(0x3FFFFFFF);
            // Hold fall display briefly so the user can see it
            delay_us(2000000);
            show_assist();
        }

        // ── Normal operation (outside assist mode) ───────────────────────
        if (!assist_mode) {

            // Display: HEX5-HEX3 = down distance, HEX2-HEX0 = forward distance
            if (dist_down < 0) display_error1();
            else               display_distance1((int)dist_down);

            if (dist_fwd < 0)  display_error2();
            else               display_distance2((int)dist_fwd);

            // ── Ledge / drop detection (sensor 1, pointing down) ─────────
            // Normal reading ≈ 5 cm. If it rises, the cane tip is over a drop.
            if (dist_down >= LEDGE_DANGER) {
                // Large drop ahead — emergency
                play_emergency_siren(0x3FFFFFFF);
            } else if (dist_down >= LEDGE_WARN_HIGH) {
                play_ledge_alert(0x3FFFFFFF);
            } else if (dist_down >= LEDGE_WARN_MID) {
                play_ledge_alert(0x3FFFFFFF / 2);
            } else if (dist_down >= LEDGE_WARN_LOW) {
                play_ledge_alert(0x3FFFFFFF / 4);
            }

            // ── Obstacle detection (sensor 2, pointing forward) ──────────
            // Only alert when something is actually close —
            // ignore open-air readings (those are handled by fall detection)
            if (dist_fwd > 0 && dist_fwd <= 100.0f) {
                unsigned int vol;
                if      (dist_fwd > 60) vol = 0x3FFFFFFF / 4;
                else if (dist_fwd > 30) vol = 0x3FFFFFFF / 2;
                else                    vol = 0x3FFFFFFF;
                play_obstacle_alert(vol);
            }
        }
    }

    return 0;
}
