/*******************************************************************************
 * Assistive cane — DE1-SoC bare-metal
 *
 * Device mounted ~5 cm above floor at base of cane.
 *
 * Sensor roles:
 *   Sensor 1 — top face, pointing DOWN
 *       Normal: reads ~5 cm to floor.
 *       Tipped forward/sideways: loses floor, reads open air (large / -1).
 *       Used for: ledge detection + fall detection (forward/sideways tips).
 *
 *   Sensor 2 — side face, pointing FORWARD
 *       Normal: reads obstacles at shin height.
 *       Tipped backward/sideways: sweeps into open air (large / -1).
 *       Used for: obstacle detection + fall detection (backward/sideways tips).
 *
 * Fall detection strategy:
 *   Either sensor reading open air → increment fall counter.
 *   Both sensors reading normal    → increment upright counter (clears fall).
 *   This catches all tipping directions.
 *
 * JP2 pin mapping:
 *   bit 3 — sensor 2 TRIG  (output)
 *   bit 4 — sensor 2 ECHO  (input)
 *   bit 5 — sensor 1 TRIG  (output)
 *   bit 6 — sensor 1 ECHO  (input)
 ******************************************************************************/

#include <stdlib.h>
#include <stdbool.h>

#define JP2_BASE        0xFF200070
#define HEX3_HEX0_BASE  0xFF200020
#define HEX5_HEX4_BASE  0xFF200030
#define AUDIO_BASE      0xFF203040
#define SAMPLE_RATE     8000

// ── Tuning ───────────────────────────────────────────────────────────────────

// A reading above this (cm) on either sensor = open air / cane tipped
// Sensor 1 normal ≈ 5 cm, so anything above ~20 cm is suspicious.
// Sensor 2 normal varies; 150 cm gives a comfortable margin.
#define S1_OPEN_AIR         20.0f
#define S2_OPEN_AIR         150.0f

// Consecutive open-air reads before declaring a fall
#define FALL_CONFIRM        3

// Consecutive normal reads before clearing fall alert (auto-upright detection)
#define UPRIGHT_CONFIRM     5

// Ledge thresholds for sensor 1 (cm). Normal = ~5 cm.
// Tune these after testing on a real kerb.
#define LEDGE_DANGER        15.0f
#define LEDGE_WARN_HIGH     10.0f
#define LEDGE_WARN_MID       8.0f
#define LEDGE_WARN_LOW       6.5f

// ─────────────────────────────────────────
// PERIPHERAL STRUCTS
// ─────────────────────────────────────────
typedef struct {
    volatile unsigned int CONTROL;
    volatile unsigned int FIFOSPACE;
    volatile unsigned int LEFTDATA;
    volatile unsigned int RIGHTDATA;
} AUDIO_t;

typedef struct {
    volatile unsigned int DATA;
    volatile unsigned int DDR;
} GPIO_t;

typedef struct {
    GPIO_t *gpio;
    int     trig_pin;
    int     echo_pin;
} HCSR04_t;

AUDIO_t      *audio = (AUDIO_t *)AUDIO_BASE;
volatile int *hex   = (volatile int *)HEX3_HEX0_BASE;
volatile int *hex54 = (volatile int *)HEX5_HEX4_BASE;
GPIO_t       *jp2   = (GPIO_t *)JP2_BASE;

const unsigned char seg7[] = {
    0x3F, 0x06, 0x5B, 0x4F, 0x66,
    0x6D, 0x7D, 0x07, 0x7F, 0x6F
};

// ─────────────────────────────────────────
// GPIO
// ─────────────────────────────────────────
void pinMode(GPIO_t *gpio, int pin, int mode) {
    if (mode == 1) gpio->DDR |=  (1 << pin);
    else           gpio->DDR &= ~(1 << pin);
}

void digitalWrite(GPIO_t *gpio, int pin, int val) {
    if (val) gpio->DATA |=  (1 << pin);
    else     gpio->DATA &= ~(1 << pin);
}

int digitalRead(GPIO_t *gpio, int pin) {
    return (gpio->DATA >> pin) & 1;
}

void delay_us(int us) {
    volatile int i;
    for (i = 0; i < us * 40; i++);
}

// ─────────────────────────────────────────
// HEX DISPLAY
// ─────────────────────────────────────────
void display_distance1(int cm) {
    if (cm > 999) cm = 999;
    if (cm < 0)   cm = 0;
    *hex54 = (seg7[(cm / 100) % 10] << 8) | seg7[(cm / 10) % 10];
    *hex   = (*hex & 0x00FFFFFF) | (seg7[cm % 10] << 24);
}

void display_distance2(int cm) {
    if (cm > 999) cm = 999;
    if (cm < 0)   cm = 0;
    *hex = (*hex & 0xFF000000)
         | (seg7[(cm / 100) % 10] << 16)
         | (seg7[(cm / 10)  % 10] <<  8)
         |  seg7[cm % 10];
}

void display_error1(void) {
    *hex54 = (0x79 << 8) | 0x50;
    *hex   = (*hex & 0x00FFFFFF) | (0x50 << 24);
}

void display_error2(void) {
    *hex = (*hex & 0xFF000000) | (0x79 << 16) | (0x50 << 8) | 0x50;
}

void show_fall(void) {
    // F A L L
    *hex54 = (0x71 << 8) | 0x77;
    *hex   = (0x38 << 24) | (0x38 << 16) | 0x0000;
}

void show_assist(void) {
    *hex54 = 0x00000000;
    *hex   = (0x77 << 24) | (0x6D << 16) | (0x6D << 8) | 0x78;
}

void show_disengage(void) {
    *hex54 = 0x00000000;
    *hex   = (0x5E << 24) | (0x06 << 16) | (0x6D << 8) | 0x79;
}

// ─────────────────────────────────────────
// AUDIO
// ─────────────────────────────────────────
static bool FIFOspace(void) {
    unsigned int fs = audio->FIFOSPACE;
    return ((fs >> 24) & 0xFF) > 0 && ((fs >> 16) & 0xFF) > 0;
}

void play_sample(int s) {
    while (!FIFOspace());
    audio->LEFTDATA  = s;
    audio->RIGHTDATA = s;
}

void play_tone(int freq, int duration_ms, int vol) {
    if (freq == 0) {
        int n = (SAMPLE_RATE * duration_ms) / 1000;
        for (int i = 0; i < n; i++) play_sample(0);
        return;
    }
    int half = SAMPLE_RATE / freq / 2;
    int n    = (SAMPLE_RATE * duration_ms) / 1000;
    int cnt  = 0;
    bool hi  = true;
    for (int i = 0; i < n; i++) {
        play_sample(hi ? vol : -vol);
        if (++cnt >= half) { hi = !hi; cnt = 0; }
    }
}

void play_obstacle_alert(int vol) {
    play_tone(1000, 100, vol);
    play_tone(0,    100, vol);
}

void play_ledge_alert(int vol) {
    play_tone(300, 400, vol);
    play_tone(0,   100, vol);
}

void play_emergency_siren(int vol) {
    play_tone(600, 300, vol);
    play_tone(800, 300, vol);
}

// ─────────────────────────────────────────
// HC-SR04
// ─────────────────────────────────────────
float distance_read(HCSR04_t *s) {
    digitalWrite(s->gpio, s->trig_pin, 0);
    delay_us(2);
    digitalWrite(s->gpio, s->trig_pin, 1);
    delay_us(10);
    digitalWrite(s->gpio, s->trig_pin, 0);

    int timeout = 1200000;
    while (digitalRead(s->gpio, s->echo_pin) == 0 && timeout-- > 0);
    if (timeout <= 0) return -1.0f;

    volatile int count = 0;
    int echo_timeout   = 1200000;
    while (digitalRead(s->gpio, s->echo_pin) == 1 && echo_timeout-- > 0)
        count++;

    return (float)count / 150.0f;
}

// ─────────────────────────────────────────
// OPEN-AIR HELPERS
// ─────────────────────────────────────────

// Returns true if sensor 1 (down) is no longer seeing the floor
bool s1_is_open(float d) {
    return (d < 0.0f || d > S1_OPEN_AIR);
}

// Returns true if sensor 2 (forward) is seeing open air
bool s2_is_open(float d) {
    return (d < 0.0f || d > S2_OPEN_AIR);
}

// Returns true if both sensors are reading normal (cane upright)
bool cane_is_upright(float d1, float d2) {
    return !s1_is_open(d1) && !s2_is_open(d2);
}

// ─────────────────────────────────────────
// FALL + UPRIGHT DETECTION
//
// Returns:
//    1  — fall confirmed (either sensor open air for FALL_CONFIRM reads)
//   -1  — upright confirmed (both normal for UPRIGHT_CONFIRM reads)
//         only meaningful while assist_mode is active
//    0  — no state change
// ─────────────────────────────────────────
int detect_fall_state(float d1, float d2) {
    static int fall_count    = 0;
    static int upright_count = 0;

    bool open    = s1_is_open(d1) || s2_is_open(d2);
    bool upright = cane_is_upright(d1, d2);

    if (open) {
        fall_count++;
        upright_count = 0;
    } else if (upright) {
        upright_count++;
        fall_count = 0;
    } else {
        // Ambiguous reading — decay both slowly
        if (fall_count    > 0) fall_count--;
        if (upright_count > 0) upright_count--;
    }

    if (fall_count >= FALL_CONFIRM) {
        fall_count    = 0;
        upright_count = 0;
        return 1;
    }

    if (upright_count >= UPRIGHT_CONFIRM) {
        fall_count    = 0;
        upright_count = 0;
        return -1;
    }

    return 0;
}

// ─────────────────────────────────────────
// MAIN
// ─────────────────────────────────────────
int main(void) {
    audio->CONTROL = 0xC;
    audio->CONTROL = 0x0;

    // Sensor 1: top, pointing down — floor/ledge
    HCSR04_t sensor1 = { jp2, 5, 6 };
    pinMode(jp2, sensor1.trig_pin, 1);
    pinMode(jp2, sensor1.echo_pin, 0);

    // Sensor 2: side, pointing forward — obstacle/fall
    HCSR04_t sensor2 = { jp2, 3, 4 };
    pinMode(jp2, sensor2.trig_pin, 1);
    pinMode(jp2, sensor2.echo_pin, 0);

    digitalWrite(jp2, sensor1.trig_pin, 0);
    digitalWrite(jp2, sensor2.trig_pin, 0);

    *hex   = 0x00000000;
    *hex54 = 0x00000000;

    int assist_mode = 0;

    while (1) {
        // ── Read sensors ─────────────────────────────────────────────────
        float dist_down = distance_read(&sensor1);
        delay_us(500);
        float dist_fwd  = distance_read(&sensor2);
        delay_us(500);

        // ── Fall / upright state machine ─────────────────────────────────
        int state = detect_fall_state(dist_down, dist_fwd);

        if (state == 1 && !assist_mode) {
            // ── Fall detected ─────────────────────────────────────────────
            assist_mode = 1;
            show_fall();
            play_emergency_siren(0x3FFFFFFF);
            play_emergency_siren(0x3FFFFFFF);
        }
        else if (state == -1 && assist_mode) {
            // ── Cane back upright — auto-clear fall alert ─────────────────
            assist_mode = 0;
            show_disengage();
            delay_us(1000000);
            *hex   = 0x00000000;
            *hex54 = 0x00000000;
        }

        // ── Normal operation (outside assist mode) ───────────────────────
        if (!assist_mode) {

            // HEX5-HEX3 = down distance, HEX2-HEX0 = forward distance
            if (dist_down < 0) display_error1();
            else               display_distance1((int)dist_down);

            if (dist_fwd  < 0) display_error2();
            else               display_distance2((int)dist_fwd);

            // ── Ledge / drop (sensor 1, down) ────────────────────────────
            // Fires when floor reading rises above normal ~5 cm baseline.
            if (dist_down >= LEDGE_DANGER) {
                play_emergency_siren(0x3FFFFFFF);
            } else if (dist_down >= LEDGE_WARN_HIGH) {
                play_ledge_alert(0x3FFFFFFF);
            } else if (dist_down >= LEDGE_WARN_MID) {
                play_ledge_alert(0x3FFFFFFF / 2);
            } else if (dist_down >= LEDGE_WARN_LOW) {
                play_ledge_alert(0x3FFFFFFF / 4);
            }

            // ── Obstacle (sensor 2, forward) ─────────────────────────────
            // Only alert on close readings — ignore open air
            // (open air is handled by fall detection, not here)
            if (dist_fwd > 0.0f && dist_fwd <= 100.0f) {
                unsigned int vol;
                if      (dist_fwd > 60) vol = 0x3FFFFFFF / 4;
                else if (dist_fwd > 30) vol = 0x3FFFFFFF / 2;
                else                    vol = 0x3FFFFFFF;
                play_obstacle_alert(vol);
            }
        }
    }

    return 0;
}
